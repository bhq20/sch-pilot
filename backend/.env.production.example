# ============================================================
#  SCH Backend — PRODUÇÃO (Cloud Run + Supabase)
# ============================================================
# Copie como .env.production e preencha os valores reais.
# NUNCA commite o .env.production no git.

# Connection string do Supabase: Project Settings → Database →
# Connection string → URI (modo Session) com senha no final.
# Formato: postgresql+psycopg2://postgres:<SENHA>@db.<PROJECT_REF>.supabase.co:5432/postgres
DATABASE_URL=postgresql+psycopg2://postgres:TROCAR_SENHA@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Chave JWT: gere uma string aleatória forte (mínimo 48 chars)
# Comando: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=TROCAR_POR_CHAVE_ALEATORIA_FORTE_MINIMO_48_CARACTERES_AQUI

ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# CORS: origens permitidas (frontend). Separe por vírgula.
CORS_ORIGINS=https://app.bhqconsultoria.com,https://sch.bhqconsultoria.com

# Cloud Run injeta PORT automaticamente (não precisa setar aqui).
